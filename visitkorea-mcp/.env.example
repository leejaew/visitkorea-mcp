# Copy this file to .env and fill in your values.
# In Replit, set these via the Secrets panel instead of a .env file.

# Your Korea Tourism Organization (KTO) service key from data.go.kr
# Obtain at: https://www.data.go.kr/data/15101753/openapi.do
# Paste the "Encoding key" (URL-encoded) or "Decoding key" (raw) — both work.
VISITKOREA_API_KEY=your_service_key_here
